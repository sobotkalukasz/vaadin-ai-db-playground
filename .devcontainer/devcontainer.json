{
  "name": "Vaadin AI DB Playground",
  "image": "mcr.microsoft.com/devcontainers/java:25",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Vaadin App",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "postCreateCommand": "./mvnw -B -DskipTests package"
}
